# Telegram
TELEGRAM_TOKEN=

# MiniMax-M2 (https://www.minimax.io/platform)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2

# App
ENV=dev                  # dev | prod
LOG_LEVEL=INFO
DATA_DIR=./empresas
DB_PATH=./data/app.sqlite

# Admin (recibe alertas de tokens, outliers, etc.)
ADMIN_TELEGRAM_CHAT_ID=

# Webhook (solo prod)
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=

# Presupuesto MiniMax (USD)
MINIMAX_BUDGET_USD=10
MINIMAX_ALERT_THRESHOLD=0.8
